{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "pp_scatter",
  "position": {
    "x": 20,
    "y": 110,
    "z": 100,
    "width": 820,
    "height": 380,
    "tabOrder": 100
  },
  "visual": {
    "visualType": "scatterChart",
    "query": {
      "queryState": {
        "X": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "PromoCost"
                }
              },
              "queryRef": "_Measures.PromoCost",
              "nativeQueryRef": "PromoCost"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "IncrementalRevenue"
                }
              },
              "queryRef": "_Measures.IncrementalRevenue",
              "nativeQueryRef": "IncrementalRevenue"
            }
          ]
        },
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "dim_promo"
                    }
                  },
                  "Property": "promo_id"
                }
              },
              "queryRef": "dim_promo.promo_id",
              "nativeQueryRef": "promo_id"
            }
          ]
        }
      }
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Promo Cost vs. Incremental Revenue'"
                }
              }
            },
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ]
    },
    "drillFilterOtherVisuals": true
  }
}