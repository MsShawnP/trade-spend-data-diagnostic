{
  "name": "OpDedRate",
  "expression": "DIVIDE(\n    CALCULATE(\n        SUM(fact_deductions[amount]),\n        fact_deductions[deduction_type] <> \"promo_billback\"\n    ),\n    SELECTEDVALUE(dim_retailer[revenue], 1),\n    0\n)",
  "formatString": "0.0%",
  "displayFolder": "Retailer Comparison"
}